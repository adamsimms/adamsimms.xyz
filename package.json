{
  "name": "adamsimms-xyz",
  "version": "1.0.0",
  "description": "Personal portfolio website for Adam Simms - technologist, designer, artist, and educator",
  "scripts": {
    "start": "npx serve .",
    "lint": "npm run lint:html && npm run lint:css",
    "lint:html": "htmlhint '**/*.html'",
    "lint:css": "stylelint 'css/styles.css' --allow-empty-input",
    "format": "prettier --write '**/*.{html,css,json,md}'",
    "validate": "npm run lint",
    "lighthouse": "npx lighthouse https://adamsimms.xyz --output=html --output-path=./lighthouse-report.html",
    "deploy": "npx wrangler pages deploy . --project-name=adamsimms-xyz",
    "deploy:preview": "npx wrangler pages deploy . --project-name=adamsimms-xyz --branch=preview",
    "cf:login": "npx wrangler login",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.html": [
      "htmlhint",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adamsimms/adamsimms.xyz"
  },
  "keywords": [
    "portfolio",
    "personal-website",
    "static-site"
  ],
  "author": "Adam Simms",
  "license": "MIT",
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "husky": "^9.0.11",
    "lighthouse": "^11.7.1",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^36.0.0",
    "wrangler": "^3.78.0"
  }
}
